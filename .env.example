# Backend-only secrets (set in Netlify environment variables, not in extension code)

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# PayPal
PAYPAL_MODE=live
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Signing secret for activation token generation
LICENSE_SIGNING_SECRET=

# Optional pricing overrides
PIXEL_RULER_PRICE_INR=99
PIXEL_RULER_PRICE_USD=1.00
SMART_CAPTURE_PRICE_INR=99
SMART_CAPTURE_PRICE_USD=1.00

# Optional branding
BUSINESS_NAME=Your Business Name
